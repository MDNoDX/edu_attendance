# PostgreSQL connection strings (Neon or Supabase).
# Neon example: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/edu_erp?sslmode=require
# Supabase example (pooled, for serverless): postgresql://postgres:password@db.xxxx.supabase.co:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://user:password@localhost:5432/edu_erp?schema=public"
# Direct (non-pooled) connection, required by Prisma migrate when using a pooler like PgBouncer/Neon pooled.
DIRECT_URL="postgresql://user:password@localhost:5432/edu_erp?schema=public"

# Secret used to sign JWT session tokens. Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-secret-value"

# Public app URL (used for absolute links, e.g. in notification payloads)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seed data: demo teacher credentials (only used by prisma/seed.ts)
SEED_TEACHER_USERNAME="teacher1"
SEED_TEACHER_PASSWORD="Teacher123!"
