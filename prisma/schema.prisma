// ============================================================================
// NadirEdu — single-role (Teacher) attendance & earnings tracker.
// Every teacher fully self-manages their own groups, students, schedule,
// attendance and payments. There is no admin/oversight role for the normal
// case — each User's data is completely isolated from every other User's
// data (a small number of separately-provisioned SUPER_ADMIN accounts can
// see across teachers from /admin; see the UserRole enum below).
// PostgreSQL. Designed for Neon + Vercel deployment.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------------

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  FINISHED
}

enum GroupStatus {
  ACTIVE
  FINISHED
  PAUSED
}

enum AttendanceStatus {
  PRESENT
  EXCUSED_ABSENT // sababli kelmadi
  UNEXCUSED_ABSENT // sababsiz kelmadi
  LATE // kechikdi
}

enum LessonSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

/// TEACHER: the normal self-service account (default for every /signup
/// registration). SUPER_ADMIN: a small number of platform-owner accounts,
/// provisioned only via the `prisma/create-admin.ts` script (never through
/// self-signup), that can see every teacher, impersonate them for support,
/// and edit/deactivate their accounts from /admin.
enum UserRole {
  TEACHER
  SUPER_ADMIN
}

// ----------------------------------------------------------------------------
// USER — a self-registering Teacher account (the normal case), or a
// separately-provisioned SUPER_ADMIN platform-owner account. A teacher's
// data is scoped to their own userId and never visible to any other
// teacher — only a SUPER_ADMIN can see across accounts.
// ----------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String

  /// firstName/lastName are the fields actually collected at signup/profile
  /// edit. `fullName` is a denormalized cache of `${firstName} ${lastName}`,
  /// kept in sync at every write (see formatFullName() in src/lib/utils.ts)
  /// so the dozens of places that only ever need to DISPLAY a name didn't
  /// all need to change when this split from a single field.
  firstName String @default("")
  lastName  String @default("")
  fullName  String
  email     String? @unique
  phone     String?
  photoUrl  String?

  role UserRole @default(TEACHER)

  /// True only for the owner-level admin(s) provisioned directly via
  /// prisma/create-admin.ts (the only way to create the very first
  /// SUPER_ADMIN). Only an owner can promote/demote other accounts to
  /// SUPER_ADMIN or change their permissions — this prevents a
  /// lower-privilege admin from ever escalating themselves or anyone else.
  /// An owner implicitly has every permission regardless of `permissions`.
  isOwner Boolean @default(false)

  /// Granular capabilities for a SUPER_ADMIN account (ignored for TEACHER).
  /// See ADMIN_PERMISSIONS in src/lib/permissions.ts for the valid set,
  /// e.g. "MANAGE_TEACHERS", "IMPERSONATE", "MANAGE_ADMINS".
  permissions String[] @default([])

  /// Default per-attended-lesson earning share in UZS, e.g. 18500.
  /// Can be overridden per-group via Group.teacherLessonRateOverride.
  defaultLessonRate Decimal @default(0) @db.Decimal(14, 2)
  specialization    String?
  bio               String?

  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  groups         Group[]
  lessonSessions LessonSession[]
  students       Student[]
  payments       Payment[]
  sessions       Session[]

  @@map("users")
}

// ----------------------------------------------------------------------------
// GROUPS — a concrete class/cohort of students, meeting on a recurring
// weekly schedule in a named room. There is no separate "Course" template
// entity — a teacher just creates a Group directly with its own name and
// monthly tuition price, which is simpler for a single-tenant self-service
// app where courses and groups were always effectively 1:1 in practice.
// ----------------------------------------------------------------------------

/// A concrete class/cohort of students, meeting on a recurring weekly
/// schedule in a named room.
model Group {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  /// Free-text subject/label, e.g. "Ingliz tili", optional.
  subject  String?
  /// Plain text room label (e.g. "10-xona") — no separate room booking
  /// system, since each teacher's schedule is independent of every other
  /// teacher's.
  roomName String

  /// Monthly tuition price charged to students in this group, in UZS.
  monthlyPrice Decimal @db.Decimal(14, 2)
  /// How many lessons are held per month, e.g. 12. Used to derive the
  /// per-lesson value: monthlyPrice / lessonsPerMonth.
  lessonsPerMonth Int

  capacity  Int         @default(15)
  status    GroupStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime?

  /// Optional override of the teacher's default per-lesson rate for this
  /// specific group.
  teacherLessonRateOverride Decimal? @db.Decimal(14, 2)

  students       Student[]
  scheduleSlots  ScheduleSlot[]
  lessonSessions LessonSession[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("groups")
}

/// The recurring weekly template for a group's lessons (e.g. Mon/Wed/Fri 14:00-15:30).
/// LessonSession rows are generated from this template for each concrete date.
model ScheduleSlot {
  id        String @id @default(cuid())
  groupId   String
  group     Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0 = Sunday ... 6 = Saturday
  startTime String // "14:00"
  endTime   String // "15:30"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@map("schedule_slots")
}

/// A concrete, date-specific lesson occurrence. Attendance is always recorded
/// against a LessonSession, never directly against a Group.
model LessonSession {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  date      DateTime            @db.Date
  startTime String
  endTime   String
  status    LessonSessionStatus @default(SCHEDULED)

  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, date])
  @@index([userId, date])
  @@map("lesson_sessions")
}

// ----------------------------------------------------------------------------
// STUDENTS
// ----------------------------------------------------------------------------

model Student {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName      String
  lastName       String
  middleName     String? // Sharif
  /// Optional — not every teacher wants/needs to record this.
  gender         Gender?
  /// Optional — not every teacher wants/needs to record this.
  birthDate      DateTime?     @db.Date
  phone          String?
  parentPhone    String
  address        String?
  passportOrIdNo String?
  photoUrl       String?
  note           String?
  status         StudentStatus @default(ACTIVE)
  startDate      DateTime      @db.Date

  groupId String
  group   Group @relation(fields: [groupId], references: [id], onDelete: Restrict)

  attendances Attendance[]
  payments    Payment[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([groupId])
  @@index([status])
  @@index([lastName, firstName])
  @@map("students")
}

// ----------------------------------------------------------------------------
// ATTENDANCE (core business logic lives in src/lib/attendance-payment.ts)
// ----------------------------------------------------------------------------

model Attendance {
  id              String           @id @default(cuid())
  studentId       String
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lessonSessionId String
  lessonSession   LessonSession    @relation(fields: [lessonSessionId], references: [id], onDelete: Cascade)
  status          AttendanceStatus
  note            String?

  /// Actual clock-in time for a LATE mark (e.g. "18:15"), so a teacher can
  /// record exactly when the student showed up, not just the status.
  /// Null for every other status.
  arrivalTime String?

  /// Amount credited to the teacher for THIS attendance record, already
  /// adjusted by the consecutive-absence cutoff rule at the time it was
  /// computed. 0 for absence statuses past the cutoff.
  teacherEarningAmount Decimal @default(0) @db.Decimal(14, 2)

  /// Value of one lesson for the student's billing (monthlyPrice / lessonsPerMonth),
  /// snapshotted at mark-time for historical accuracy even if price changes later.
  lessonValueSnapshot Decimal @default(0) @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, lessonSessionId])
  @@index([studentId])
  @@index([lessonSessionId])
  @@index([status])
  @@map("attendances")
}

// ----------------------------------------------------------------------------
// PAYMENTS
// ----------------------------------------------------------------------------

model Payment {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /// Billing period, first day of month, e.g. 2026-07-01.
  billingMonth DateTime      @db.Date
  amountDue    Decimal       @db.Decimal(14, 2)
  amountPaid   Decimal       @default(0) @db.Decimal(14, 2)
  status       PaymentStatus @default(UNPAID)

  transactions PaymentTransaction[]

  note      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([studentId, billingMonth])
  @@index([userId])
  @@index([status])
  @@index([billingMonth])
  @@map("payments")
}

// ----------------------------------------------------------------------------
// RATE LIMITING — sliding-window attempt tracker backed by this same
// Postgres database instead of a separate Redis/Upstash service. Fine at
// this app's traffic scale; see src/lib/rate-limit.ts. Used for login
// brute-force protection, signup abuse throttling, and username-check
// enumeration throttling.
// ----------------------------------------------------------------------------

model RateLimitAttempt {
  id        String   @id @default(cuid())
  /// e.g. "login:user:someusername", "login:ip:1.2.3.4", "signup:ip:1.2.3.4".
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@map("rate_limit_attempts")
}

// ----------------------------------------------------------------------------
// SESSIONS — one row per issued login, so the profile page can show "which
// devices are logged into your account" and let a teacher revoke a device
// that isn't theirs. The JWT itself stays the actual auth mechanism (no
// per-request DB lookup for every action) — this table is only consulted at
// login (to create a row) and on the profile page (to list/revoke). A
// session is force-logged-out by checking `revokedAt` only where it's
// already being read (profile page's own requests), not on every request.
// ----------------------------------------------------------------------------

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Short random id embedded in the JWT itself (`sessionId` claim) — lets a
  /// specific device's token be identified/labeled without storing the
  /// token itself.
  tokenId   String   @unique
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
  lastSeenAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@map("sessions")
}

model PaymentTransaction {
  id            String        @id @default(cuid())
  paymentId     String
  payment       Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount        Decimal       @db.Decimal(14, 2)
  method        PaymentMethod @default(CASH)
  receiptNumber String?
  note          String?
  paidAt        DateTime      @default(now())

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@map("payment_transactions")
}
